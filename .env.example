# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle / postgres direct connection (Settings → Database → Connection string → URI)
DATABASE_URL=

# App environment — `development` redirects all outgoing email to EMAIL_DEV_TO
# so test sends never reach real clients/coaches. Set to `production` for the
# live deploy. Falls back to NODE_ENV if unset.
APP_ENV=

# Resend — transactional email (Phase 5.5). Verify the sender domain in the Resend
# dashboard before use; RESEND_FROM_EMAIL must live on a verified domain. While
# using the `onboarding@resend.dev` sandbox sender, recipients are restricted to
# the email registered on your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# In non-production APP_ENV, every send is rewritten to this address. Leave
# unset to disable the override (sends go to the real recipient).
EMAIL_DEV_TO=
