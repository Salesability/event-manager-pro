# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle / postgres direct connection (Settings → Database → Connection string → URI)
DATABASE_URL=

# App environment — set to `production` on the live deploy. Used as a redundant
# guard alongside EMAIL_FORCE_DEV_REDIRECT: if APP_ENV=production, email is never
# redirected even if the dev-redirect vars are set.
APP_ENV=

# Resend — transactional email (Phase 5.5). Verify the sender domain in the Resend
# dashboard before use; RESEND_FROM_EMAIL must live on a verified domain. While
# using the `onboarding@resend.dev` sandbox sender, recipients are restricted to
# the email registered on your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Dev-mode email redirect — opt-in. Set EMAIL_FORCE_DEV_REDIRECT=true AND
# EMAIL_DEV_TO=<your inbox> in non-production environments to rewrite every
# outgoing send to your inbox (with `[DEV→original@example.com]` prefixed on
# the subject). Real-send is the default; both vars must be set explicitly to
# enable the redirect. Production deploys must NOT set EMAIL_FORCE_DEV_REDIRECT.
EMAIL_FORCE_DEV_REDIRECT=
EMAIL_DEV_TO=
