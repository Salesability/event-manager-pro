# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle / postgres direct connection (Settings → Database → Connection string → URI)
DATABASE_URL=

# App environment — MUST be `production` on the live deploy. Acts as the
# explicit opt-out of dev-redirect: if APP_ENV != 'production' AND EMAIL_DEV_TO
# is unset, sendEmail refuses rather than risk silently real-sending from a
# misconfigured non-prod env (see src/lib/email/send.ts).
APP_ENV=

# Canonical origin for outbound share links (e.g. https://your-app.example.com).
# Required for email sends — there is no header-based fallback to prevent a
# Host-header injection from planting attacker URLs in coach emails. Also used
# by /auth/callback for OAuth/magic-link redirects.
SITE_URL=

# Resend — transactional email. Verify the sender domain in the Resend
# dashboard before use; RESEND_FROM_EMAIL must live on a verified domain. While
# using the `onboarding@resend.dev` sandbox sender, recipients are restricted to
# the email registered on your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Dev-mode email redirect (Phase 7 of 0019 inverted the default). Set
# EMAIL_DEV_TO=<your inbox> in any non-production environment. Every outbound
# send is rewritten to your inbox (subject prefixed with `[DEV→original@…]`).
# When APP_ENV != 'production' AND EMAIL_DEV_TO is unset, sendEmail refuses
# rather than real-sending. EMAIL_FORCE_DEV_REDIRECT is no longer consulted.
EMAIL_DEV_TO=

# Google Cloud Storage — blob storage for rendered Quote/Contract/Invoice
# PDFs (Phase 1 of 0026-quote-pdf). Code is the source of truth for document
# layout; the bucket holds rendered output only (e.g. quotes/{id}/{rev}.pdf).
# On Cloud Run leave GCS_CREDENTIALS_JSON unset and let workload identity
# provide creds; locally either point GOOGLE_APPLICATION_CREDENTIALS at a
# service-account JSON file or paste the JSON inline into GCS_CREDENTIALS_JSON.
# GCS_PROJECT_ID is optional — when unset, ADC infers it from the credential.
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CREDENTIALS_JSON=

# MSA_TEMPLATE_VERSION is the active MSA prose version (e.g. "2026-05-12"),
# denormalized into master_service_agreements.templateVersion at draft-create
# time; bump manually whenever the prose in src/lib/pdf/render-msa.ts changes.
# Provider-agnostic — used by both the rendered MSA PDF and the audit log.
MSA_TEMPLATE_VERSION=

# BoldSign — bundled MSA + first-Quote e-signature envelopes (chunk
# 0051-dropbox-sign-to-boldsign). BOLDSIGN_API_KEY authenticates the
# server-side SDK (DocumentApi); BOLDSIGN_WEBHOOK_SECRET is the
# per-endpoint shared secret for HMAC-SHA256 verification of inbound
# webhook callbacks at /api/boldsign/webhook — verified BEFORE any state
# mutation. Signing scheme: `X-BoldSign-Signature: t=<epoch>, s0=<hex>`
# over `timestamp + "." + rawBody` (Stripe-style).
#
# BOLDSIGN_API_BASE_URL picks the regional API host — BoldSign segments
# accounts by region: US = api.boldsign.com (the SDK default), EU =
# api-eu.boldsign.com, CA = api-ca.boldsign.com. Leave unset for a US
# account; set to the matching regional host for EU/CA accounts (a
# CA-region key 401s against the US host with an empty body, which the
# SDK surfaces as "Invalid authentication"). Sandbox vs. production is
# orthogonal to region — it's signalled per-request via the `isSandbox`
# flag derived from APP_ENV, not by host.
#
# Dev-inbox redirect for BoldSign's vendor-sent signing-request email
# reuses the SAME `EMAIL_DEV_TO` env var declared above for Resend (no
# separate `BOLDSIGN_DEV_TO`). Rationale: same concept ("non-prod mail
# of any kind goes to this inbox"), two separate vendors — splitting
# the env creates a foot-gun where one is set and the other isn't, and
# signing-request mail leaks while transactional mail is safe (or vice
# versa). When APP_ENV != 'production' AND EMAIL_DEV_TO is unset,
# sendSignatureRequest refuses to send (loud error, no silent leak to
# a real customer inbox via BoldSign's sandbox infrastructure — its
# `isSandbox: true` flag stamps documents as non-binding but does NOT
# stop BoldSign from emailing the recipient). MSA_TEMPLATE_VERSION
# (above) is provider-agnostic and stays as-is.
BOLDSIGN_API_KEY=
BOLDSIGN_API_BASE_URL=
BOLDSIGN_WEBHOOK_SECRET=
